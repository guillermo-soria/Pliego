# Turso — https://turso.tech
# 1. Crear DB: turso db create pliego
# 2. Obtener URL: turso db show pliego --url
# 3. Crear token: turso db tokens create pliego
TURSO_DATABASE_URL=libsql://pliego-<tu-usuario>.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Clerk — https://clerk.com
# Crear app en dashboard.clerk.com y copiar las keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (dejar así)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
